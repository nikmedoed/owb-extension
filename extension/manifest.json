{
  "manifest_version": 3,
  "name": "OWB Tools",
  "description": "Ozon/WB exporter + price monitor with local/server sync",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "downloads",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.ozon.ru/*",
    "*://*.ozon.com/*",
    "*://*.ozon.kz/*",
    "*://*.ozon.by/*",
    "*://*.ozon.uz/*",
    "*://*.ozon.am/*",
    "*://*.ozon.kg/*",
    "*://*.ozon.ge/*",
    "*://*.wildberries.ru/*",
    "*://*.wildberries.by/*",
    "*://*.wildberries.kz/*",
    "*://*.wildberries.uz/*",
    "*://*.wildberries.am/*",
    "*://*.wildberries.kg/*",
    "*://*.wildberries.ge/*",
    "*://*.wb.ru/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://[::1]/*",
    "https://127.0.0.1/*",
    "https://localhost/*",
    "https://[::1]/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "OWB Tools",
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "*://*.ozon.ru/*",
        "*://*.ozon.com/*",
        "*://*.ozon.kz/*",
        "*://*.ozon.by/*",
        "*://*.ozon.uz/*",
        "*://*.ozon.am/*",
        "*://*.ozon.kg/*",
        "*://*.ozon.ge/*",
        "*://*.wildberries.ru/*",
        "*://*.wildberries.by/*",
        "*://*.wildberries.kz/*",
        "*://*.wildberries.uz/*",
        "*://*.wildberries.am/*",
        "*://*.wildberries.kg/*",
        "*://*.wildberries.ge/*",
        "*://*.wb.ru/*"
      ],
      "js": [
        "content/mp-core.js",
        "content/exporter.js",
        "content/price-monitor.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
